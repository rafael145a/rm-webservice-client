{
  "name": "rm-webservice-client",
  "version": "0.4.0",
  "description": "Cliente TypeScript não oficial para consumir wsDataServer e wsConsultaSQL do TOTVS RM via SOAP.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafael145a/rm-webservice-client.git"
  },
  "bugs": {
    "url": "https://github.com/rafael145a/rm-webservice-client/issues"
  },
  "homepage": "https://github.com/rafael145a/rm-webservice-client#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "import": "./dist/catalog/index.js",
      "require": "./dist/catalog/index.cjs"
    }
  },
  "bin": {
    "rmws": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build:catalog": "tsx scripts/build-catalog.ts"
  },
  "keywords": [
    "totvs",
    "rm",
    "soap",
    "wsdataserver",
    "wsconsultasql",
    "soap-client",
    "typescript"
  ],
  "dependencies": {
    "cac": "^6.7.14",
    "fast-xml-parser": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
